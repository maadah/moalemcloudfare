# ============================================================
# Kimi (Moonshot AI) API Configuration
# ============================================================
# Get your key from: https://platform.moonshot.ai/console/api-keys
# Key format: starts with "sk-"
MOONSHOT_API_KEY=YOUR_MOONSHOT_API_KEY_HERE

# Optional: Backup key for redundancy / key rotation
# KIMI_API_KEY=YOUR_BACKUP_KEY_HERE

# Optional: Use OpenRouter instead of Moonshot direct
# Get your key from: https://openrouter.ai/keys
# Key format: starts with "sk-or-v1-"
# OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE

# ============================================================
# Firebase Configuration (VITE_ prefix = embedded in client)
# ============================================================
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_AUTH_DOMAIN
VITE_FIREBASE_STORAGE_BUCKET=YOUR_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_DATABASE_ID=YOUR_DATABASE_ID
