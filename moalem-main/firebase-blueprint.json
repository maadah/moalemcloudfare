{
  "entities": {
    "Exam": {
      "title": "Exam",
      "description": "Represents an exam created by a teacher.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the exam." },
        "totalGrade": { "type": "number", "description": "The total grade for the exam (e.g., 100)." },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "answer": { "type": "string" },
              "grade": { "type": "number" },
              "type": { "type": "string", "enum": ["text", "true-false", "multiple-choice", "fill-in-the-blanks"] },
              "options": { "type": "array", "items": { "type": "string" } },
              "subQuestions": { "type": "array", "items": { "$ref": "Question" } }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorUid": { "type": "string" }
      },
      "required": ["title", "totalGrade", "questions", "authorUid"]
    },
    "StudentResult": {
      "title": "StudentResult",
      "description": "Represents the grading results for a student's exam.",
      "type": "object",
      "properties": {
        "examId": { "type": "string" },
        "sessionId": { "type": "string", "description": "The ID of the grading session this result belongs to." },
        "studentName": { "type": "string" },
        "totalGrade": { "type": "number" },
        "gradings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "questionId": { "type": "string" },
              "studentAnswer": { "type": "string" },
              "grade": { "type": "number" },
              "feedback": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorUid": { "type": "string" }
      },
      "required": ["examId", "studentName", "totalGrade", "gradings", "authorUid"]
    },
    "GradingSession": {
      "title": "GradingSession",
      "description": "Represents a batch of graded student results.",
      "type": "object",
      "properties": {
        "examId": { "type": "string" },
        "examTitle": { "type": "string" },
        "studentCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorUid": { "type": "string" }
      },
      "required": ["examId", "examTitle", "studentCount", "authorUid"]
    },
    "User": {
      "title": "User",
      "description": "Represents a user of the system and their usage limits.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "pageLimit": { "type": "number" },
        "pagesUsed": { "type": "number" },
        "questionsCount": { "type": "number", "description": "Number of questions extracted by this user." },
        "gradingsCount": { "type": "number", "description": "Number of papers graded by this user." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "status", "role", "pageLimit", "pagesUsed", "questionsCount", "gradingsCount"]
    }
  },
  "firestore": {
    "/exams/{examId}": {
      "schema": "Exam",
      "description": "Collection of exams created by teachers."
    },
    "/results/{resultId}": {
      "schema": "StudentResult",
      "description": "Collection of graded student results."
    },
    "/sessions/{sessionId}": {
      "schema": "GradingSession",
      "description": "Collection of grading sessions (batches)."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles and permissions."
    }
  }
}
